#!/usr/bin/env bash
# wgmgr — WireGuard 管理器（v2ray-agent 风格菜单）
# 装到 /usr/local/bin/wgmgr

set -euo pipefail

# ---------- lib discovery ----------
_LIB_DIR=""
for candidate in \
    "${WG_INSTALL_LIB_DIR:-}" \
    "/usr/local/share/wgmgr/lib" \
    "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")/lib" \
    "/etc/wireguard/.wgmgr/lib"; do
    if [[ -n "${candidate}" && -f "${candidate}/common.sh" ]]; then
        _LIB_DIR="${candidate}"
        break
    fi
done

if [[ -z "${_LIB_DIR}" ]]; then
    echo "[✗] wgmgr: lib/ not found." >&2
    exit 1
fi

# shellcheck disable=SC1091
source "${_LIB_DIR}/common.sh"
source "${_LIB_DIR}/network.sh"
source "${_LIB_DIR}/server.sh"
source "${_LIB_DIR}/client.sh"

WG_DIR="/etc/wireguard"
WG_CONF="${WG_DIR}/wg0.conf"
WG_CLIENTS_DIR="${WG_DIR}/clients"

# ---------- Color echo (v2ray-agent style) ----------
C_WHITE=$'\033[37m'
echo_red()    { printf '\033[31m%s\033[0m\n' "$*"; }
echo_sky()    { printf '\033[1;36m%s\033[0m\n' "$*"; }
echo_green()  { printf '\033[32m%s\033[0m\n' "$*"; }
echo_yellow() { printf '\033[33m%s\033[0m\n' "$*"; }

# ---------- Helpers ----------
# Resolve client name: supports "1" (first client) or full name
resolve_client_name() {
    local input="$1"
    if [[ -z "${input}" ]]; then
        echo ""
        return
    fi
    # Check if it's a name that exists
    if [[ -f "${WG_CLIENTS_DIR}/${input}.conf" ]]; then
        echo "${input}"
        return
    fi
    # Check if it's a number (1-based index of sorted clients)
    if [[ "${input}" =~ ^[0-9]+$ ]]; then
        local idx=0
        while IFS= read -r -d '' f; do
            ((idx++)) || true
            if [[ "${idx}" -eq "${input}" ]]; then
                basename "${f}" .conf
                return
            fi
        done < <(find "${WG_CLIENTS_DIR}" -maxdepth 1 -name "*.conf" -type f -print0 2>/dev/null | sort -z)
    fi
    # Not found
    echo "${input}"
}
ASSUME_YES=0
WG_ARGS=()
for arg in "$@"; do
    case "${arg}" in
        --yes|-y) ASSUME_YES=1 ;;
        *)        WG_ARGS+=("${arg}") ;;
    esac
done
set -- "${WG_ARGS[@]+"${WG_ARGS[@]}"}"

# ---------- Helpers ----------
require_installed() {
    if [[ ! -f "${WG_CONF}" ]]; then
        echo_red "WireGuard 未安装，请先运行 install.sh"
        exit 1
    fi
}

read_server_state() {
    if [[ ! -f "${WG_CONF}" ]]; then
        echo_red "配置文件 ${WG_CONF} 不存在"
        exit 1
    fi
    SERVER_PUBLIC="$(grep -E '^#?PublicKey' "${WG_CONF}" 2>/dev/null | awk '{print $3}' | head -1 || true)"
    if [[ -z "${SERVER_PUBLIC}" ]] && has_cmd wg; then
        SERVER_PUBLIC="$(wg show wg0 public-key 2>/dev/null || true)"
    fi
    if [[ -z "${SERVER_PUBLIC}" ]]; then
        echo_red "无法获取服务器公钥"
        exit 1
    fi
    SERVER_PORT="$(grep -E '^ListenPort' "${WG_CONF}" | awk '{print $3}' || true)"
    SERVER_ADDRESS="$(grep -E '^Address' "${WG_CONF}" | awk '{print $3}' | head -1 || true)"
    PUBLIC_IP="${PUBLIC_IP:-}"
    if [[ -z "${PUBLIC_IP}" ]] && has_cmd curl; then
        PUBLIC_IP="$(curl -4 -fsSL --max-time 5 https://ifconfig.me 2>/dev/null | tr -d '[:space:]' || echo "")"
    fi
    if [[ -n "${PUBLIC_IP}" ]]; then
        SERVER_ENDPOINT="${PUBLIC_IP}:${SERVER_PORT}"
    else
        SERVER_ENDPOINT="<vps-ip>:${SERVER_PORT}"
    fi
    if [[ "${SERVER_ADDRESS}" =~ ^([0-9.]+)/ ]]; then
        ip="${BASH_REMATCH[1]}"
        SERVER_SUBNET="${ip%.*}.0/24"
    else
        SERVER_SUBNET="10.0.0.0/24"
    fi
    if [[ -d "${WG_CLIENTS_DIR}" ]]; then
        SERVER_DNS="$(grep -hE '^DNS' "${WG_CLIENTS_DIR}"/*.conf 2>/dev/null | head -1 | awk '{for(i=3;i<=NF;i++) printf "%s%s", (i>3?OFS:""), $i} END{print ""}' || true)"
        SERVER_DNS="${SERVER_DNS%,}"
    fi
    SERVER_DNS="${SERVER_DNS:-1.1.1.1, 8.8.8.8}"
    return 0
}

confirm_destructive() {
    local label="$1"
    if [[ "${ASSUME_YES}" == "1" ]]; then return 0; fi
    if [[ ! -t 0 ]]; then return 1; fi
    local reply
    printf '\033[33m%s [y/N]: \033[0m' "${label}"
    read -r reply
    case "${reply}" in [yY]|[yY][eE][sS]) return 0 ;; *) return 1 ;; esac
}

prompt_input() {
    local label="$1"
    local reply
    printf '\033[33m%s: \033[0m' "${label}" >&2
    read -r reply
    printf '%s' "${reply}"
}

# ---------- Separator ----------
separator() {
    echo_red "=============================================================="
}

# ---------- Subcommands ----------
cmd_list() {
    require_installed
    read_server_state
    separator
    echo_sky "当前账户列表"
    separator
    list_clients
    echo ""
    echo_green "服务器公钥: ${SERVER_PUBLIC}"
    echo_green "Endpoint:   ${SERVER_ENDPOINT}"
}

cmd_add() {
    require_installed
    read_server_state
    local name="${1:-}"
    if [[ -z "${name}" ]]; then
        name="$(prompt_input '请输入账户名 (如: iphone, mac, router)')"
    fi
    if [[ -z "${name}" ]]; then
        echo_red "账户名不能为空"
        exit 1
    fi
    if ! deliver_client "${name}" "${SERVER_PUBLIC}" "${SERVER_ENDPOINT}" "${SERVER_SUBNET}" "${SERVER_DNS}" 1; then
        return
    fi
    if [[ "${DRYRUN}" != "1" ]]; then
        local conf="${WG_CLIENTS_DIR}/${name}.conf"
        local client_pub client_ip psk
        client_pub="$(grep -E '^PublicKey' "${conf}" | awk '{print $3}' | head -1)"
        client_ip="$(grep -E '^Address' "${conf}" | awk '{print $3}' | head -1 | cut -d/ -f1)"
        psk="$(grep -E '^PresharedKey' "${conf}" | awk '{print $3}' || true)"

        add_peer_to_server "${name}" "${client_pub}" "${client_ip}" "${psk}"

        # Apply to running wg0 immediately. Use wg syncconf (safer than wg set
        # which doesn't always persist + can be confused by PSK via stdin).
        if has_cmd wg; then
            # Apply to running wg0 immediately. Use wg syncconf (safer than
            # wg set which doesn't always persist + is fiddly with PSK over stdin).
            wg set wg0 peer "${client_pub}" remove 2>/dev/null || true

            # Append to wg0.conf (idempotent: skip if already present)
            if ! grep -q "^# client: ${name}\$" "${WG_CONF}"; then
                cat >> "${WG_CONF}" <<EOF

# client: ${name}
[Peer]
PublicKey = ${client_pub}
PresharedKey = ${psk}
AllowedIPs = ${client_ip}/32
EOF
            fi

            # Re-parse and apply without dropping the interface
            wg-quick strip wg0 2>/dev/null | wg syncconf wg0 - 2>/dev/null || true
        fi
    fi
    echo ""
    echo_green "账户 '${name}' 添加成功！"
    cmd_qr "${name}"
}

cmd_add_interactive() {
    cmd_add ""
    read -r -p "按 Enter 返回菜单..."
}

cmd_remove() {
    require_installed
    local name="${1:-}"
    if [[ -z "${name}" ]]; then
        list_clients
        echo ""
        name="$(resolve_client_name "$(prompt_input '请输入序号或账户名')")"
    fi
    if [[ -z "${name}" ]]; then
        echo_red "账户名不能为空"
        return
    fi
    local conf="${WG_CLIENTS_DIR}/${name}.conf"
    if [[ ! -f "${conf}" ]]; then
        echo_red "账户 '${name}' 不存在"
        return
    fi
    local client_ip
    client_ip="$(grep -E '^Address' "${conf}" | awk '{print $3}' | head -1)"
    echo ""
    echo_yellow "即将删除以下账户:"
    echo_red  "  名称: ${name}"
    echo_red  "  IP:   ${client_ip}"
    echo_red  "  文件: ${conf}"
    if ! confirm_destructive "确认删除 '${name}'?"; then
        echo_sky "已取消"
        return
    fi
    # Live remove from wg0
    if has_cmd wg; then
        local client_pub
        client_pub="$(grep -E '^PublicKey' "${conf}" | awk '{print $3}' | head -1)"
        if [[ -n "${client_pub}" ]]; then
            wg set wg0 peer "${client_pub}" remove 2>/dev/null || true
        fi
    fi
    remove_client "${name}"
    echo_green "账户 '${name}' 已删除"
}

cmd_qr() {
    require_installed
    local name="${1:-}"
    if [[ -z "${name}" ]]; then
        list_clients
        echo ""
        name="$(resolve_client_name "$(prompt_input '请输入序号或账户名')")"
    fi
    local conf="${WG_CLIENTS_DIR}/${name}.conf"
    if [[ ! -f "${conf}" ]]; then
        echo_red "账户 '${name}' 不存在"
        return
    fi
    separator
    echo_sky "'${name}' 配置信息"
    separator
    echo ""
    echo_green "────────── 客户端配置 ──────────"
    cat "${conf}"
    echo_green "────────────────────────────────────"
    echo ""
    echo_yellow "二维码（手机扫）:"
    render_qr_terminal "${conf}" || true
    echo ""
    echo_green "下载命令:"
    echo "  scp root@${PUBLIC_IP:-<vps-ip>}:${conf} ./"
}

cmd_config() {
    require_installed
    read_server_state
    separator
    echo_sky "服务器配置"
    separator
    echo_yellow "  公钥 (PublicKey):    ${C_WHITE}${SERVER_PUBLIC}"
    echo_yellow "  Endpoint:            ${C_WHITE}${SERVER_ENDPOINT}"
    echo_yellow "  监听端口 (Port):     ${C_WHITE}${SERVER_PORT}"
    echo_yellow "  子网 (Subnet):       ${C_WHITE}${SERVER_SUBNET}"
    echo_yellow "  DNS:                 ${C_WHITE}${SERVER_DNS}"
    echo_yellow "  配置路径:            ${C_WHITE}${WG_CONF}"
    echo_yellow "  客户端目录:          ${C_WHITE}${WG_CLIENTS_DIR}"
    echo ""
    echo_green "  当前账户:"
    list_clients
}

cmd_status() {
    require_installed
    separator
    echo_sky "服务状态"
    separator
    if has_cmd wg; then
        wg show
    fi
    echo ""
    if has_cmd systemctl; then
        systemctl status wg-quick@wg0.service --no-pager 2>/dev/null || true
    fi
}

cmd_restart() {
    require_installed
    if has_cmd systemctl; then
        systemctl restart wg-quick@wg0.service 2>/dev/null || true
        echo_green "服务已重启"
    else
        echo_red "systemctl 不可用"
    fi
}

cmd_uninstall() {
    separator
    echo_red "即将卸载 WireGuard"
    separator
    echo_yellow "  此操作将:"
    echo_yellow "  · 停止并禁用 wg-quick@wg0 服务"
    echo_yellow "  · 删除所有密钥和配置文件"
    echo_yellow "  · 删除 iptables 规则"
    echo_yellow "  · 删除 /usr/local/bin/wgmgr"
    echo ""
    echo_yellow "  (保留软件包: wireguard / wireguard-tools / qrencode)"
    echo_yellow "  (保留包方便 'sudo wgmgr reinstall' 重装不用重下)"
    echo ""
    if ! confirm_destructive "是否确认卸载安装内容？[y/N]"; then
        echo_sky "放弃卸载"
        return
    fi
    # Built-in uninstall (don't rely on external uninstall.sh)
    do_full_uninstall "no"
}

# Performs complete cleanup of WireGuard from the system.
# Argument: "yes" = also purge apt/dnf packages; "no" = skip packages.
do_full_uninstall() {
    local purge_pkgs="${1:-no}"
    echo_yellow "[1/7] 停止并禁用 wg-quick@wg0 服务..."
    if has_cmd systemctl; then
        systemctl stop wg-quick@wg0.service 2>/dev/null || true
        systemctl disable wg-quick@wg0.service 2>/dev/null || true
    fi
    echo_yellow "[2/7] 卸载任何剩余 wg-quick 残留接口..."
    if has_cmd ip; then
        for iface in $(ip link show 2>/dev/null | awk -F: '/wg[0-9]+/ {gsub(/ /, "", $2); print $2}'); do
            ip link delete "${iface}" 2>/dev/null || true
        done
    fi
    echo_yellow "[3/7] 清理 iptables NAT / FORWARD 规则..."
    local egress_iface
    egress_iface="$(ip route 2>/dev/null | awk '/default/ {print $5; exit}')"
    if [[ -z "${egress_iface}" ]]; then egress_iface="eth0"; fi
    if has_cmd iptables; then
        # All known wg subnets + the default 10.0.0.0/24
        for subnet in "10.0.0.0/24" "10.10.0.0/24" "192.168.100.0/24"; do
            iptables -t nat -D POSTROUTING -s "${subnet}" -o "${egress_iface}" -j MASQUERADE 2>/dev/null || true
            iptables -D FORWARD -s "${subnet}" -j ACCEPT 2>/dev/null || true
            iptables -D FORWARD -d "${subnet}" -j ACCEPT 2>/dev/null || true
        done
        # Also flush any wg-related chain leftovers (the PostUp rule)
        iptables -D FORWARD -i wg+ -j ACCEPT 2>/dev/null || true
        iptables -D FORWARD -o wg+ -j ACCEPT 2>/dev/null || true
        if has_cmd netfilter-persistent; then
            netfilter-persistent save 2>/dev/null || true
        elif has_cmd service; then
            service iptables save 2>/dev/null || true
        fi
    fi
    echo_yellow "[4/7] 删除 /etc/wireguard/ 整树（含所有 client conf / png）..."
    rm -rf /etc/wireguard
    echo_yellow "[5/7] 删除 IP forwarding 配置..."
    rm -f /etc/sysctl.d/99-wireguard.conf
    # Restore default IP forwarding (kernel still has it, but reset sysctl file)
    if has_cmd sysctl; then
        sysctl -w net.ipv4.ip_forward=0 >/dev/null 2>&1 || true
    fi
    echo_yellow "[6/7] 删除 wgmgr 二进制和 lib..."
    rm -f /usr/local/bin/wgmgr
    rm -rf /usr/local/share/wgmgr
    # Also clear any leftover helper scripts in /tmp
    rm -f /tmp/wg-install-lib/* /tmp/wgmgr-download 2>/dev/null || true
    rm -rf /tmp/wg-install-lib 2>/dev/null || true
    echo_yellow "[7/7] 验证清理..."
    if [[ -d /etc/wireguard ]]; then
        echo_red "  ⚠ /etc/wireguard 还在（强制删除）"
        rm -rf /etc/wireguard
    fi
    if [[ -f /usr/local/bin/wgmgr ]]; then
        echo_red "  ⚠ wgmgr 还在（强制删除）"
        rm -f /usr/local/bin/wgmgr
    fi
    echo ""
    separator
    echo_green "✓ WireGuard 全部清除完成"
    separator

    if [[ "${purge_pkgs}" == "yes" ]]; then
        echo_yellow "卸载软件包 (wireguard-tools / qrencode)..."
        if has_cmd apt-get; then
            DEBIAN_FRONTEND=noninteractive apt-get purge -y --auto-remove wireguard wireguard-tools qrencode iptables-persistent 2>/dev/null || true
        elif has_cmd dnf; then
            dnf remove -y wireguard-tools qrencode iptables-services 2>/dev/null || true
        fi
        echo_green "✓ 软件包已卸载"
    fi

    echo ""
    echo_sky "系统状态:"
    if has_cmd wg; then
        echo "  wg 命令还在（来自 wireguard-tools），可保留"
    fi
    if has_cmd systemctl; then
        if systemctl list-unit-files wg-quick@.service 2>/dev/null | grep -q wg-quick; then
            echo "  wg-quick@.service 单元还在（来自 wireguard 包），可保留"
        fi
    fi
    echo ""
    echo_sky "重新安装: curl -fsSL https://raw.githubusercontent.com/doodomilker/wireguard-vps-installer/main/install.sh | sudo bash"
    echo_sky "           或: sudo wgmgr reinstall   （一键清完再装）"
    echo_sky "完全删除软件包: sudo wgmgr purge      （含 wireguard / qrencode 等）"
}

cmd_purge() {
    separator
    echo_red "即将完全删除 WireGuard (含软件包)"
    separator
    echo_yellow "  此操作将:"
    echo_yellow "  · 7 步硬清所有配置（与 uninstall 相同）"
    echo_yellow "  · 卸载软件包:"
    echo_yellow "      Debian/Ubuntu:  wireguard wireguard-tools qrencode iptables-persistent"
    echo_yellow "      CentOS/RHEL:    wireguard-tools qrencode iptables-services"
    echo ""
    echo_yellow "  提示: 装回来要重新下大包, 慢一点. 不需要可以选 9 (卸载不卸包)"
    echo ""
    if ! confirm_destructive "是否确认完全删除 WireGuard？[y/N]"; then
        echo_sky "放弃卸载"
        return
    fi
    do_full_uninstall "yes"
}

cmd_reinstall() {
    separator
    echo_red "即将重装 WireGuard（清空当前所有配置）"
    separator
    echo_yellow "  此操作将:"
    echo_yellow "  · 完全清除当前 WireGuard（7 步硬清）"
    echo_yellow "  · 自动重新运行 install.sh（恢复全新安装）"
    echo ""
    echo_yellow "  你将获得:"
    echo_yellow "  · 新的 server keypair（之前的会作废）"
    echo_yellow "  · 新的 client1（IP 仍是 10.0.0.2）"
    echo_yellow "  · 新 client1.conf + PNG QR + 终端 ASCII QR"
    echo ""
    echo_yellow "  提示: 已有 client 的设备需要重新导入新 conf！"
    echo ""
    if ! confirm_destructive "确认重装?"; then
        echo_sky "已取消"
        return
    fi

    # 7-step cleanup
    do_full_uninstall "yes"

    # Re-run install.sh automatically
    echo ""
    separator
    echo_sky "重装：开始 install.sh"
    separator
    local installer=""
    for c in \
        "/usr/local/share/wgmgr/install.sh" \
        "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")/install.sh" \
        "./install.sh"; do
        if [[ -f "$c" ]]; then
            installer="$c"
            break
        fi
    done

    if [[ -n "$installer" ]]; then
        bash "$installer" 2>&1 | tail -40
    else
        echo_yellow "本地 install.sh 不存在，从 GitHub 拉..."
        bash <(curl -fsSL https://raw.githubusercontent.com/doodomilker/wireguard-vps-installer/main/install.sh)
    fi
}

# ---------- Main Menu ----------
show_menu() {
    require_installed
    read_server_state

    while true; do
        separator
        echo_sky "       WGMGR — WireGuard 管理器"
        separator
        echo_yellow "  Server: ${C_WHITE}${SERVER_ENDPOINT}"
        echo_yellow "  子网:   ${C_WHITE}${SERVER_SUBNET}"
        echo ""
        echo_sky "━━━━━━━━━━ 账户管理 ━━━━━━━━━━━"
        echo_yellow "  1. 查看所有账户"
        echo_yellow "  2. 添加新账户"
        echo_yellow "  3. 删除账户"
        echo_yellow "  4. 查看账户配置（含二维码）"
        echo ""
        echo_sky "━━━━━━━━━━ 服务管理 ━━━━━━━━━━━"
        echo_yellow "  5. 查看服务状态"
        echo_yellow "  6. 重启服务"
        echo ""
        echo_sky "━━━━━━━━━━ 系统 ━━━━━━━━━━━"
        echo_yellow "  7. 查看服务器配置"
        echo_yellow "  8. 重装 WireGuard (清空再装)"
        echo_yellow "  9. 卸载 WireGuard (只清除)"
        echo_yellow "  0. 退出"
        separator
        printf '\033[33m请选择 [0-9]: \033[0m'

        local choice
        read -r choice || break

        case "${choice}" in
            1) cmd_list; read -r -p "按 Enter 返回菜单..." _ ;;
            2) cmd_add_interactive ;;
            3) cmd_remove ""; read -r -p "按 Enter 返回菜单..." _ ;;
            4) cmd_qr ""; read -r -p "按 Enter 返回菜单..." _ ;;
            5) cmd_status; read -r -p "按 Enter 返回菜单..." _ ;;
            6) cmd_restart; read -r -p "按 Enter 返回菜单..." _ ;;
            7) cmd_config; read -r -p "按 Enter 返回菜单..." _ ;;
            8) cmd_reinstall; read -r -p "按 Enter 返回菜单..." _ ;;
            9) cmd_uninstall; read -r -p "按 Enter 返回菜单..." _ ;;
            0|q|Q) exit 0 ;;
            *) echo_red "无效选项: ${choice}"; read -r -p "按 Enter 继续..." _ ;;
        esac
    done
}

# ---------- Main Dispatch ----------
case "${1:-menu}" in
    menu|"")              show_menu ;;
    add)                  shift; cmd_add "$@" ;;
    remove|rm)            shift; cmd_remove "$@" ;;
    list|ls)              cmd_list ;;
    qr|show)              shift; cmd_qr "$@" ;;
    config|cfg)           cmd_config ;;
    status|st)            cmd_status ;;
    restart)              cmd_restart ;;
    reinstall)             shift; cmd_reinstall "$@" ;;
    uninstall)             shift; cmd_uninstall "$@" ;;
    purge|rm-pkgs)         shift; cmd_purge "$@" ;;
    -h|--help|help)
        cat <<EOF
wgmgr — WireGuard 管理器

用法:
  sudo wgmgr                    交互菜单（v2ray-agent 风格）
  sudo wgmgr add <name>         添加账户
  sudo wgmgr remove <name>      删除账户
  sudo wgmgr list               列出所有账户
  sudo wgmgr qr <name>          查看账户配置 + 二维码
  sudo wgmgr config             查看服务器配置
  sudo wgmgr status             查看服务状态
  sudo wgmgr restart            重启服务
  sudo wgmgr reinstall          重装 (清空所有配置再装一遍)
  sudo wgmgr uninstall          卸载 (只清除, 保留软件包)
  sudo wgmgr purge              完全删除 (含 wireguard / qrencode 等软件包)

选项:
  --yes, -y   跳过确认（脚本模式）
EOF
        ;;
    *)
        echo_red "未知子命令: $1"
        exit 1
        ;;
esac
